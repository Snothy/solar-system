{
  "name": "spinning-ring",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "cd physics-wasm && cargo test",
    "build:wasm": "cd physics-wasm && wasm-pack build --target web",
    "build": "npm run build:wasm && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "pull-data": "npx tsx scripts/pull-data.ts",
    "unit-test": "node scripts/generate-test-report.js",
    "test:integration": "export TEST_TIMESTAMP=$(date +%Y-%m-%dT%H-%M-%S) && cd physics-wasm && cargo test integration --release -- --nocapture",
    "export-bodies": "npx tsx scripts/export_bodies.ts"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "idb": "^8.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.181.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}